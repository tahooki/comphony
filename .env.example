# Copy to .env for local use. This file is safe to commit; .env is ignored.

# Core paths
COMPHONY_ROOT=/Users/you/Documents/comphony
COMPHONY_REPO_ROOT=/Users/you/Documents/comphony/repos
COMPHONY_WORKSPACE_ROOT=/Users/you/Documents/comphony/workspaces
COMPHONY_WORKFLOW_ROOT=/Users/you/Documents/comphony/workflows

# Symphony runtime
SYMPHONY_BIN=/Users/you/Documents/symphony/elixir/bin/symphony
SYMPHONY_PORT=4000
SYMPHONY_DASHBOARD_URL=http://127.0.0.1:4000/
COMPHONY_DESK_PORT=4100
IDEA_LAB_PM_PORT=4101
IDEA_LAB_RESEARCH_PORT=4102
PROJECT_MANAGING_PORT=4103
PRODUCT_CORE_PORT=4104
MISE_BIN=/Users/you/.local/bin/mise

# Linear
LINEAR_API_KEY=
LINEAR_TEAM_ID=
LINEAR_TEAM_NAME=
LINEAR_PROJECT_NAMES=Comphony Desk,Idea Lab,Project Managing,Product - Core
COMPHONY_DESK_PROJECT_ID=
COMPHONY_DESK_PROJECT_SLUG=
IDEA_LAB_PROJECT_ID=
IDEA_LAB_PROJECT_SLUG=
PROJECT_MANAGING_PROJECT_ID=
PROJECT_MANAGING_PROJECT_SLUG=
PRODUCT_CORE_PROJECT_ID=
PRODUCT_CORE_PROJECT_SLUG=
LINEAR_STATE_ID_INBOX=
LINEAR_STATE_ID_CLARIFYING=
LINEAR_STATE_ID_TRIAGED=
LINEAR_STATE_ID_WAITING=
LINEAR_STATE_ID_REPORTED=
LINEAR_STATE_ID_PLANNING=
LINEAR_STATE_ID_RESEARCH=
LINEAR_STATE_ID_TODO=
LINEAR_STATE_ID_IN_PROGRESS=
LINEAR_STATE_ID_HUMAN_REVIEW=
LINEAR_STATE_ID_DONE=

# Optional defaults for generated local workflows
PRODUCT_REPO_SLUG=product-core
PROJECT_ADMIN_REPO_SLUG=project-admin
DEFAULT_REPO_BRANCH=main
WORKFLOW_STRATEGY=role-relay
