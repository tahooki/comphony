{
  "name": "comphony",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first company operating system runtime scaffold",
  "type": "module",
  "scripts": {
    "comphony": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "tsx --test tests/**/*.test.ts",
    "validate:config": "tsx src/cli.ts validate",
    "server:start": "tsx src/cli.ts server start"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
