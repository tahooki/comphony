# macOS
.DS_Store

# Local environment and secrets
.env
.env.*
*.local
!.env.example

# Local mission file derived from the template
MISSION.md

# Runtime leftovers
*.log
*.pid
tmp/
__pycache__/
runtime-data/*
!runtime-data/.gitkeep
node_modules/
dist/

# Local source repos cloned or created by each user
repos/*
!repos/.gitkeep

# Issue-specific workspaces
workspaces/*
!workspaces/.gitkeep

# Real executable workflow files for the local machine
workflows/*
!workflows/.gitkeep
